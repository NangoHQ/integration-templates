        "owner": "ACCOUNTADMIN",
        "text": "CREATE OR REPLACE VIEW NANGO_TEST_DB.SALES.ORDERS_SUMMARY AS SELECT c.CUSTOMER_ID, c.EMAIL, c.COMPANY, c.PLAN, COUNT(o.ORDER_ID) AS TOTAL_ORDERS, SUM(o.AMOUNT) AS TOTAL_SPEND FROM NANGO_TEST_DB.SALES.CUSTOMERS c LEFT JOIN NANGO_TEST_DB.SALES.ORDERS o ON c.CUSTOMER_ID = o.CUSTOMER_ID GROUP BY c.CUSTOMER_ID, c.EMAIL, c.COMPANY, c.PLAN",
        "is_secure": false,
        "is_materialized": false,
        "change_tracking": "OFF"
      }
    ]
